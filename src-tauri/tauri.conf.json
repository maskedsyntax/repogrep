{
  "productName": "repogrep",
  "version": "0.1.0",
  "identifier": "com.repogrep.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "capabilities": ["default"],
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "windows": [
      {
        "title": "repogrep – Local Code Search",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "visible": true,
        "center": true,
        "focus": true
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
